{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTML Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "貯金管理アプリ"],
      "port": 8080
    },
    {
      "name": "Static HTML Server (Node npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "貯金管理アプリ", "-p", "3000"],
      "port": 3000
    }
  ]
}
